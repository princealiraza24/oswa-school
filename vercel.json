{
  "rewrites": [
    { "source": "/api/:path*",       "destination": "/api/server.js" },
    { "source": "/manifest.json",    "destination": "/public/manifest.json" },
    { "source": "/sw.js",            "destination": "/public/sw.js" },
    { "source": "/school.config.js", "destination": "/school.config.js" },
    { "source": "/icons/:path*",     "destination": "/public/icons/:path*" },
    { "source": "/src/:path*",       "destination": "/public/src/:path*" },
    { "source": "/:path*",           "destination": "/public/index.html" }
  ]
}
